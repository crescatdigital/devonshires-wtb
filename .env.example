# Copy this file to .env.local and fill in the values. Never commit .env.local.

# ── Supabase (CMS content + leads) ──────────────────────────────────────────
# Public — exposed to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — used to insert public form submissions (leads) bypassing RLS.
# Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only — used by scripts/ (migration + seed). Not exposed to the browser.
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_NAME=postgres

# ── SMTP (website form / lead notification emails) ──────────────────────────
# Credentials for the mailbox that sends lead notifications (e.g. Microsoft 365
# or Google Workspace for devonshiresclaims.co.uk).
SMTP_HOST=
SMTP_PORT=587
# Optional — defaults to true for port 465, false otherwise. Set "true" to force
# implicit TLS.
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=
# The "from" address shown on notification emails. Defaults to SMTP_USER if unset.
SMTP_FROM=
# Where lead notifications are delivered (the firm's enquiries inbox).
LEAD_NOTIFICATION_TO=admin@devonshiresclaims.co.uk
